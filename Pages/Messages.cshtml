@page
@model CodeCircle.Pages.MessagesModel
@{
    ViewData["Title"] = "Messages";
}

<div style="display: flex; height: 80vh; min-height: 700px; border: 1px solid var(--border-color); border-radius: var(--radius-lg); overflow: hidden;">
    
  
    <div style="width: 350px; background-color: var(--bg-dark); border-right: 1px solid var(--border-color); display: flex; flex-direction: column;">
        
        <!-- Header -->
        <div style="padding: 24px; display: flex; justify-content: space-between; align-items: center;">
            <h2 style="margin: 0; font-size: 18px; font-weight: bold; color: var(--text-primary);">Messages</h2>
            <span style="background-color: rgba(34, 197, 94, 0.1); color: var(--brand-green); font-size: 12px; padding: 2px 8px; border-radius: 12px; border: 1px solid var(--brand-green);">3 unread</span>
        </div>

        <!-- Search Box -->
        <div style="padding: 0 24px 24px 24px;">
            <input type="text" placeholder="Search conversations..." style="width: 100%; background-color: #050505; border: 1px solid var(--border-color); color: var(--text-primary); padding: 10px 16px; border-radius: var(--radius-md);" />
        </div>

        <!-- Threads -->
        <div style="flex: 1; overflow-y: auto;">
            
            <!-- Thread 1 (Active) -->
            <div style="padding: 16px 24px; border-left: 3px solid var(--brand-green); background-color: #111a11; cursor: pointer;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span style="width: 32px; height: 32px; border-radius: 50%; background-color: #1a3320; color: var(--brand-green); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold;">SR</span>
                        <div>
                            <span style="color: var(--text-primary); font-weight: 500; font-size: 14px; display: block;">Sara Reeves</span>
                            <span style="background-color: #1f3652; color: #60a5fa; font-size: 10px; padding: 2px 6px; border-radius: 4px; display: inline-block; margin-top: 2px;">Collab request</span>
                        </div>
                    </div>
                    <span style="color: var(--brand-green); font-size: 12px;">2m</span>
                </div>
                <div style="color: var(--text-muted); font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 8px;">
                    That sounds amazing! I'd love to have ...
                </div>
            </div>

            <!-- Thread 2 -->
            <div style="padding: 16px 24px; cursor: pointer; border-bottom: 1px solid var(--border-color);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span style="width: 32px; height: 32px; border-radius: 50%; background-color: #1a2333; color: #60a5fa; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold;">MJ</span>
                        <div>
                            <span style="color: var(--text-primary); font-weight: 500; font-size: 14px; display: block;">Marcus Jones</span>
                            <span style="background-color: #1a2e1a; color: var(--brand-green); font-size: 10px; padding: 2px 6px; border-radius: 4px; display: inline-block; margin-top: 2px;">Direct message</span>
                        </div>
                    </div>
                    <span style="color: var(--text-muted); font-size: 12px;">1h</span>
                </div>
                <div style="color: var(--text-muted); font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 8px;">
                    Hey! Saw your DevFlow update — ho...
                </div>
            </div>

            <!-- Thread 3 -->
            <div style="padding: 16px 24px; cursor: pointer; border-bottom: 1px solid var(--border-color);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span style="width: 32px; height: 32px; border-radius: 50%; background-color: #311c34; color: #d8b4fe; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold;">PL</span>
                        <div>
                            <span style="color: var(--text-primary); font-weight: 500; font-size: 14px; display: block;">Priya L.</span>
                            <span style="background-color: #1f3652; color: #60a5fa; font-size: 10px; padding: 2px 6px; border-radius: 4px; display: inline-block; margin-top: 2px;">Collab request</span>
                        </div>
                    </div>
                    <span style="color: var(--text-muted); font-size: 12px;">3h</span>
                </div>
                <div style="color: var(--text-muted); font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 8px;">
                    Would you be open to collaborating o...
                </div>
            </div>
            
            <!-- Thread 4 -->
            <div style="padding: 16px 24px; cursor: pointer; border-bottom: 1px solid var(--border-color);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span style="width: 32px; height: 32px; border-radius: 50%; background-color: #33261a; color: #facc15; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold;">TL</span>
                        <div>
                            <span style="color: var(--text-primary); font-weight: 500; font-size: 14px; display: block;">Tom Li</span>
                        </div>
                    </div>
                    <span style="color: var(--text-muted); font-size: 12px;">Yesterday</span>
                </div>
                <div style="color: var(--text-muted); font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 8px;">
                    Thanks for the feedback on my PR app...
                </div>
            </div>

            <!-- Thread 5 -->
            <div style="padding: 16px 24px; cursor: pointer;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                    <div style="display: flex; align-items: center; gap: 12px;">
                        <span style="width: 32px; height: 32px; border-radius: 50%; background-color: #331a1a; color: #f87171; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold;">DO</span>
                        <div>
                            <span style="color: var(--text-primary); font-weight: 500; font-size: 14px; display: block;">Dana Ortiz</span>
                        </div>
                    </div>
                    <span style="color: var(--text-muted); font-size: 12px;">2 days</span>
                </div>
                <div style="color: var(--text-muted); font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 8px;">
                    We should sync on the open source co...
                </div>
            </div>

        </div>
    </div>

    <!-- Right Panel: Active Chat -->
    <div style="flex: 1; display: flex; flex-direction: column; background-color: var(--panel-bg);">
        
        <!-- Header -->
        <div style="padding: 24px; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center;">
            <div style="display: flex; align-items: center; gap: 12px;">
                <span style="width: 40px; height: 40px; border-radius: 50%; background-color: #1a3320; color: var(--brand-green); display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: bold;">SR</span>
                <div>
                    <span style="color: var(--text-primary); font-weight: bold; font-size: 16px; display: block;">Sara Reeves</span>
                    <div style="display: flex; align-items: center; gap: 6px; margin-top: 2px;">
                        <span style="width: 8px; height: 8px; border-radius: 50%; background-color: var(--brand-green); display: inline-block;"></span>
                        <span style="color: var(--brand-green); font-size: 12px;">Online now</span>
                    </div>
                </div>
            </div>
            <div style="display: flex; gap: 12px;">
                <button class="btn-outline-dark" style="font-size: 13px; padding: 6px 16px;">View profile</button>
                <button class="btn-outline-dark" style="font-size: 13px; padding: 6px 12px;">...</button>
            </div>
        </div>

        <!-- Chat Area -->
        <div style="flex: 1; padding: 24px; overflow-y: auto; display: flex; flex-direction: column; gap: 20px;">
            
            <!-- Collab Context Card -->
            <div style="background-color: var(--bg-dark); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 16px 20px; display: flex; justify-content: space-between; align-items: center;">
                <div style="display: flex; align-items: center; gap: 16px;">
                    <div style="width: 36px; height: 36px; border-radius: 8px; background-color: #151a15; border: 1px solid var(--border-color); display: flex; align-items: center; justify-content: center;">
                        <span style="color: var(--brand-green); font-size: 16px;">⏱</span>
                    </div>
                    <div>
                        <span style="color: var(--text-muted); font-size: 12px; display: block; margin-bottom: 4px;">Collab context</span>
                        <span style="color: var(--text-primary); font-weight: bold; font-size: 14px;">DevFlow × HealthLog</span>
                    </div>
                </div>
                <span style="background-color: #1f3652; color: #60a5fa; font-size: 12px; padding: 4px 12px; border-radius: 16px;">Pending response</span>
            </div>

            <!-- Date Separator -->
            <div style="display: flex; align-items: center; margin: 20px 0;">
                <div style="flex: 1; height: 1px; background-color: var(--border-color);"></div>
                <span style="color: var(--text-muted); font-size: 12px; padding: 0 16px;">Today</span>
                <div style="flex: 1; height: 1px; background-color: var(--border-color);"></div>
            </div>

            <!-- System Message: Collab Request -->
            <div style="display: flex; justify-content: center;">
                <div style="background-color: #111a11; border: 1px solid var(--brand-green); border-radius: var(--radius-lg); padding: 20px; width: 100%; max-width: 600px;">
                    <div style="color: var(--brand-green); font-size: 10px; font-weight: bold; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; display: flex; align-items: center; gap: 6px;">
                        <span>👋</span> COLLAB REQUEST RECEIVED
                    </div>
                    <div style="color: var(--text-primary); font-weight: bold; font-size: 14px; margin-bottom: 12px;">
                        DevFlow — AI code review tool
                    </div>
                    <div style="color: var(--text-muted); font-size: 13px; line-height: 1.5; margin-bottom: 20px;">
                        Hi Alex! I've been following HealthLog since you posted it. I'm an AI engineer and I think I can really help with the data insights layer. Would love to chat!
                    </div>
                    <div style="display: flex; gap: 12px;">
                        <button class="btn-green" style="padding: 8px 16px; font-size: 13px; font-weight: bold;">Accept request</button>
                        <button class="btn-outline-dark" style="padding: 8px 16px; font-size: 13px;">Decline</button>
                    </div>
                </div>
            </div>

            <!-- Sara's Message -->
            <div style="display: flex; gap: 16px; margin-top: 10px;">
                <span style="width: 32px; height: 32px; border-radius: 50%; background-color: #1a3320; color: var(--brand-green); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold; flex-shrink: 0;">SR</span>
                <div>
                    <span style="color: var(--text-muted); font-size: 11px; margin-bottom: 6px; display: block;">2:14 PM</span>
                    <div style="color: var(--text-muted); font-size: 13px; line-height: 1.5;">
                        We should sync on the open source collab idea I mentioned in the feed — I think there's something really cool we could ship together.
                    </div>
                </div>
            </div>

            <div style="display: flex; gap: 16px; margin-top: 10px;">
                <span style="width: 32px; height: 32px; border-radius: 50%; background-color: #331a1a; color: #f87171; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold; flex-shrink: 0;">DO</span>
                <div>
                    <span style="color: var(--text-muted); font-size: 11px; margin-bottom: 6px; display: block;">2 days ago</span>
                </div>
            </div>

        </div>

        <!-- Input Area -->
        <div style="padding: 24px; border-top: 1px solid var(--border-color);">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                <span style="width: 8px; height: 8px; border-radius: 50%; background-color: var(--brand-green);"></span>
                <span style="color: var(--text-muted); font-size: 12px;">Sara Reeves is online</span>
            </div>
            <div style="display: flex; align-items: center; gap: 12px;">
                <button style="background: transparent; border: none; color: var(--text-muted); cursor: pointer; padding: 8px;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
                    </svg>
                </button>
                <div style="flex: 1; position: relative;">
                    <input type="text" placeholder="Write a message..." style="width: 100%; background-color: var(--bg-dark); border: 1px solid var(--border-color); color: var(--text-primary); padding: 14px 16px; border-radius: var(--radius-md); padding-right: 50px;" />
                    <button style="position: absolute; right: 8px; top: 50%; transform: translateY(-50%); background-color: #1a3320; color: var(--brand-green); border: none; width: 32px; height: 32px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; cursor: pointer;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="22" y1="2" x2="11" y2="13"></line>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
