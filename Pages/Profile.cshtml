@page
@{
    ViewData["Title"] = "My Profile";

    // Dynamic Auth
    string fullName = User.Identity != null && User.Identity.IsAuthenticated ? User.Identity.Name : "Alex Kim";
    string initials = "AK";
    string handle = "@alexkim";
    string handleBuilds = "@alexbuilds";

    if (!string.IsNullOrWhiteSpace(fullName) && fullName != "Alex Kim")
    {
        var nameParts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (nameParts.Length > 1)
        {
            initials = $"{nameParts[0][0]}{nameParts[nameParts.Length - 1][0]}".ToUpper();
        }
        else if (nameParts.Length == 1)
        {
            initials = nameParts[0].Substring(0, Math.Min(2, nameParts[0].Length)).ToUpper();
        }
        string cleanName = fullName.ToLower().Replace(" ", "");
        handle = "@" + cleanName;
        handleBuilds = "@" + cleanName + "builds";
    }
}

<!-- 1. TOP HEADER (Bulletproof Inline Flex Layout) -->
<div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 40px; margin-top: 20px;">

    <!-- Left Side: Avatar and Bio -->
    <div style="display: flex; gap: 20px;">
        <div class="wall-avatar" style="width: 100px; height: 100px; font-size: 36px; background-color: #1a3320; color: var(--brand-green); border: 2px solid #22c55e;">
            @initials
        </div>

        <div>
            <h2 style="font-weight: bold; color: white; margin-bottom: 4px;">@fullName</h2>
            <p class="text-muted" style="font-size: 13px;">@handle · Member since March 2025</p>
            <p style="font-size: 14px; max-width: 600px; color: #ccc; margin-bottom: 16px;">
                Full-stack developer building in public. Passionate about AI tooling and developer experience. Currently shipping DevFlow — an AI code review tool.
            </p>

            <div style="display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap;">
                <span class="skill-tag">React</span>
                <span class="skill-tag">Node.js</span>
                <span class="skill-tag">Python</span>
                <span class="skill-tag">AI / LLM</span>
                <span class="skill-tag">SaaS</span>
            </div>

            <div style="display: flex; gap: 8px;">
                <a href="#" class="link-tag" style="text-decoration: none;">🌐 @(handle.Replace("@", "")).dev</a>
                <a href="#" class="link-tag" style="text-decoration: none;">💻 github</a>
                <a href="#" class="link-tag" style="text-decoration: none;">in /in/@(handle.Replace("@", ""))</a>
            </div>
        </div>
    </div>

    <!-- Right Side: Action Buttons -->
    <div style="display: flex; flex-direction: column; gap: 12px; width: 160px; text-align: center;">
        <button class="btn btn-green w-100 py-2" style="font-weight: 500; font-size: 13px;">👋 Request collab</button>
        <button class="btn" style="background: transparent; color: var(--text-muted); border: 1px solid #333; padding: 6px; font-size: 13px;">Message</button>
        <button class="btn" style="background: transparent; color: var(--text-muted); border: 1px solid #333; padding: 6px; font-size: 13px;">View in feed</button>
    </div>

</div>

<!-- 2. STATS ROW (Bulletproof Inline Flex Layout) -->
<div style="display: flex; flex-direction: row; gap: 20px; margin-bottom: 40px; width: 100%;">
    <div class="dashboard-card text-center mb-0" style="flex: 1; padding: 24px 10px;">
        <h3 style="color: var(--brand-green); font-size: 24px; font-weight: bold; margin-bottom: 4px;">2</h3>
        <span class="text-muted" style="font-size: 12px;">Projects</span>
    </div>
    <div class="dashboard-card text-center mb-0" style="flex: 1; padding: 24px 10px;">
        <h3 style="color: #06b6d4; font-size: 24px; font-weight: bold; margin-bottom: 4px;">14</h3>
        <span class="text-muted" style="font-size: 12px;">Updates posted</span>
    </div>
    <div class="dashboard-card text-center mb-0" style="flex: 1; padding: 24px 10px;">
        <h3 style="color: #f97316; font-size: 24px; font-weight: bold; margin-bottom: 4px;">36</h3>
        <span class="text-muted" style="font-size: 12px;">Comments received</span>
    </div>
    <div class="dashboard-card text-center mb-0" style="flex: 1; padding: 24px 10px;">
        <h3 style="color: #eab308; font-size: 24px; font-weight: bold; margin-bottom: 4px;">8</h3>
        <span class="text-muted" style="font-size: 12px;">Collab requests</span>
    </div>
</div>

<!-- 3. MAIN DASHBOARD SPLIT -->
<div class="feed-layout">

    <!-- LEFT COLUMN: Projects & Badges -->
    <div class="feed-main">
        <h6 class="section-header">Projects</h6>

        <!-- DevFlow Project -->
        <div class="dashboard-card" style="max-width: 100%;">
            <span class="badge-building">● Building</span>
            <h5 class="mt-3 text-white">DevFlow <span class="text-muted">— AI code review tool</span></h5>
            <p class="text-muted" style="font-size: 13px;">Automated contextual code review on PRs using LLMs. Integrates with GitHub and GitLab.</p>
            <div class="progress-section mt-4 mb-3">
                <div class="d-flex justify-content-end mb-1" style="font-size: 11px; color: var(--text-muted);">42%</div>
                <div class="progress-track"><div class="progress-fill" style="width: 42%;"></div></div>
            </div>
            <div class="d-flex gap-2">
                <span class="skill-tag" style="background-color: transparent;">✓ Auth done</span>
                <span class="skill-tag" style="background-color: transparent;">✓ DB schema</span>
                <span class="link-tag">○ Review engine</span>
            </div>
        </div>
        <!-- CLI Toolkit Project -->
        <div class="dashboard-card" style="max-width: 100%;">
            <span class="badge-completed" style="color: #3b82f6; border-color: #3b82f6; background-color: rgba(59, 130, 246, 0.1);">✓ Completed</span>
            <h5 class="mt-3 text-white">CLI Toolkit <span class="text-muted">— dev productivity scripts</span></h5>
            <p class="text-muted" style="font-size: 13px;">A collection of shell utilities for automating common dev workflows. Open source, 200+ stars.</p>
            <div class="progress-section mt-4 mb-0">
                <div class="d-flex justify-content-end mb-1" style="font-size: 11px; color: var(--text-muted);">100%</div>
                <div class="progress-track"><div class="progress-fill" style="width: 100%; background-color: #3b82f6;"></div></div>
            </div>
        </div>
        <h6 class="section-header mt-5">Badges Earned</h6>
        <div class="dashboard-card py-4 mb-0" style="display: flex; flex-direction: row; flex-wrap: wrap; gap: 40px; justify-content: center;">
            <div class="text-center">
                <div style="font-size: 28px;">🔥</div>
                <div class="text-muted mt-2" style="font-size: 11px;">7-day streak</div>
            </div>
            <div class="text-center">
                <div style="font-size: 28px;">🌱</div>
                <div class="text-muted mt-2" style="font-size: 11px;">First post</div>
            </div>
            <div class="text-center">
                <div style="font-size: 28px;">🫶</div>
                <div class="text-muted mt-2" style="font-size: 11px;">Collaborator</div>
            </div>
            <div class="text-center">
                <div style="font-size: 28px;">🚀</div>
                <div class="text-muted mt-2" style="font-size: 11px;">Launched</div>
            </div>
            <div class="text-center">
                <div style="font-size: 28px;">🏆</div>
                <div class="text-muted mt-2" style="font-size: 11px;">Wall of fame</div>
            </div>
        </div>
    </div>
    <!-- RIGHT COLUMN: Activity & Support -->
    <div class="feed-widgets">
        <h6 class="section-header">Recent Activity</h6>
        <div class="dashboard-card">
            <div class="activity-row">
                <span class="activity-dot text-green">●</span>
                <div>
                    <div style="font-size: 13px;">Posted a milestone update on <span class="text-green">DevFlow</span> — Auth system shipped</div>
                    <div class="text-muted mt-1" style="font-size: 11px;">2 min ago</div>
                </div>
            </div>
            <div class="activity-row">
                <span class="activity-dot" style="color: #3b82f6;">●</span>
                <div>
                    <div style="font-size: 13px;">Commented on <span style="color: #3b82f6;">QuickInvoice</span></div>
                    <div class="text-muted mt-1" style="font-size: 11px;">4 hrs ago</div>
                </div>
            </div>
            <div class="activity-row">
                <span class="activity-dot" style="color: #eab308;">●</span>
                <div>
                    <div style="font-size: 13px;">Raised a collab request on <span style="color: #eab308;">HealthLog</span></div>
                    <div class="text-muted mt-1" style="font-size: 11px;">Yesterday</div>
                </div>
            </div>
            <div class="activity-row">
                <span class="activity-dot text-green">●</span>
                <div>
                    <div style="font-size: 13px;">Updated progress on <span class="text-green">DevFlow</span> to 42%</div>
                    <div class="text-muted mt-1" style="font-size: 11px;">2 days ago</div>
                </div>
            </div>
        </div>
        <h6 class="section-header mt-4">Seeking Support</h6>
        <div class="dashboard-card mb-0">
            <p style="font-size: 13px; color: #ddd; line-height: 1.6;">
                Looking for an <span class="text-green">LLM engineer</span> to help build the review engine for DevFlow. Part-time collab welcome.
            </p>
            <button class="btn btn-green w-100 mt-3 py-2" style="font-weight: 500;">👋 Offer to collaborate</button>
        </div>
    </div>
</div>