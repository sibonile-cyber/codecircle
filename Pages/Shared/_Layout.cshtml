@{
    // 1. Get the current logged-in user's name (fallback to a placeholder if they aren't logged in)
    string fullName = (User.Identity?.IsAuthenticated == true ? User.Identity?.Name : null) ?? "Alex Kim";

    // 2. Automatically calculate the initials (e.g., "Marcus Jones" -> "MJ")
    string initials = "AK";
    if (!string.IsNullOrWhiteSpace(fullName))
    {
        var nameParts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        // If they have a first and last name, grab the first letter of both
        if (nameParts.Length > 1)
        {
            initials = $"{nameParts[0][0]}{nameParts[nameParts.Length - 1][0]}".ToUpper();
        }
        // If it's just one word containing their username, grab the first two letters
        else if (nameParts.Length == 1)
        {
            initials = nameParts[0].Substring(0, Math.Min(2, nameParts[0].Length)).ToUpper();
        }
    }
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodeCircle</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CodeCircle.styles.css" asp-append-version="true" />
</head>
<body>
    <body>
        <!-- 1. We wrap everything in a master container -->
        <div class="app-container">

            <!-- 2. The Left Sidebar Navigation -->
            <aside class="sidebar">
                <div class="brand">
                    <span style="color: var(--brand-green);">●</span> CodeCircle <span class="beta-tag">beta</span>
                </div>

                <!-- Workspace Links -->
                <div class="sidebar-section">
                    <span class="section-title">WORKSPACE</span>
                    <a href="/Index" class="nav-item">
                        <span class="nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="7" height="7" rx="2"></rect>
                                <rect x="14" y="3" width="7" height="7" rx="2"></rect>
                                <rect x="14" y="14" width="7" height="7" rx="2"></rect>
                                <rect x="3" y="14" width="7" height="7" rx="2"></rect>
                            </svg>
                        </span>
                        <span>Live Feed</span>
                    </a>
                    <a href="/MyProjects" class="nav-item">
                        <span class="nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M3 7a2 2 0 0 1 2-2h5l2 2h8a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"></path>
                            </svg>
                        </span>
                        <span>My Projects</span>
                    </a>
                    <a href="/CreateProject" class="nav-item">
                        <span class="nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="9"></circle>
                                <path d="M12 8v8M8 12h8"></path>
                            </svg>
                        </span>
                        <span>New Entry</span>
                    </a>
                </div>

                <!-- Community Links -->
                <div class="sidebar-section">
                    <span class="section-title">COMMUNITY</span>
                    <a href="/CelebrationWall" class="nav-item">
                        <span class="nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.77 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                            </svg>
                        </span>
                        <span>Celebration Wall</span>
                    </a>
                    <a href="/Messages" class="nav-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Messages" ? "active" : "")">
                        <span class="nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v8z"></path>
                            </svg>
                        </span>
                        <span>Messages</span>
                        <span class="nav-badge">3</span>
                    </a>
                    <a href="/CollabRequests" class="nav-item">
                        <span class="nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M16 11a3 3 0 0 1 5 2v1a3 3 0 0 1-3 3h-2"></path>
                                <path d="M8 11a3 3 0 0 0-5 2v1a3 3 0 0 0 3 3h2"></path>
                                <path d="M8 11l4 4 4-4"></path>
                                <path d="M12 15v6"></path>
                            </svg>
                        </span>
                        <span>Collab Requests</span>
                        <span class="nav-badge">2</span>
                    </a>
                </div>

                <div class="sidebar-spacer"></div>

                <!-- Profile Link at the bottom -->
                <div class="sidebar-section">
                    <span class="section-title">ACCOUNT</span>
                    <a href="/Profile" class="nav-item">
                        <span class="nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                        </span>
                        <span>Profile</span>
                    </a>
                    <a href="/Register" class="nav-item">
                        <span class="nav-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                                <path d="M19 8v6"></path>
                                <path d="M22 11h-6"></path>
                            </svg>
                        </span>
                        <span>Create account</span>
                    </a>

                </div>
            </aside>

            <!-- 3. The Main Content Area (Everything to the right of the sidebar) -->
            <div class="main-content">

                <!-- A small top bar just for your Avatar -->
                <div class="top-bar">
                    <div class="user-avatar">@initials</div>
                </div>

                <!-- 4. This is where your page content (like Live Feed) actually loads! -->
                <main role="main">
                    @RenderBody()
                </main>

            </div>
        </div>

        <!-- Keep your scripts at the bottom -->
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>

</body>
</html>