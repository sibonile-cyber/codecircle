<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodeCircle</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CodeCircle.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-container">

     
        <aside class="sidebar">
            <div class="sidebar-logo">
                🚀 CodeCircle
            </div>

            <ul class="sidebar-menu">
               
                <a href="/" class="menu-item active">
                    🏠 Home
                </a>
                <a href="/CreateProject" class="menu-item">
                    📁 My Projects
                </a>
                <a href="/CelebrationWall" class="menu-item">
                    🏆 Celebration Wall
                </a>
                <a href="/Profile/Sarah%20Dev" class="menu-item">
                    👤 Profile
                </a>
            </ul>          
            <div style="padding: 0 15px; margin-top: 20px;">
                <a href="/CreatePost" class="btn w-100" style="background: linear-gradient(135deg, #238636 0%, #2ea043 100%); color: white; font-weight: 600; border-radius: 8px; box-shadow: 0 0 15px rgba(35, 134, 54, 0.3); padding: 12px; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Post a Win
                </a>
            </div>

            <div style="margin-top: auto;">
               
                <partial name="_LoginPartial" />
            </div>
        </aside>
      
        <main class="main-wrapper">
            @RenderBody()
        </main>

    </div>
  
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>