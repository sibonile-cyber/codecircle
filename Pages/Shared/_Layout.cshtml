<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodeCircle</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CodeCircle.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-container">

        <!-- Left Column: The Dashboard Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                🚀 CodeCircle
            </div>

            <ul class="sidebar-menu">
                <!-- Our Active Tab -->
                <a href="/" class="menu-item active">
                    🏠 Home
                </a>
                <a href="/CreateProject" class="menu-item">
                    📁 My Projects
                </a>
                <a href="/CelebrationWall" class="menu-item">
                    🏆 Celebration Wall
                </a>
                <a href="/" class="menu-item">
                    👤 Profile
                </a>
            </ul>
            <div style="margin-top: auto;">
                <!-- We keep our ASP.NET Login tools at the bottom of the sidebar -->
                <partial name="_LoginPartial" />
            </div>
        </aside>
        <!-- Right Column: Where all our Feed and Pages load -->
        <main class="main-wrapper">
            @RenderBody()
        </main>

    </div>
    <!-- Required for ASP.NET functionality -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>