@{
    // 1. Get the current logged-in user's name (fallback to a placeholder if they aren't logged in)
    string fullName = User.Identity != null && User.Identity.IsAuthenticated
                      ? User.Identity.Name
                      : "Alex Kim";

    // 2. Automatically calculate the initials (e.g., "Marcus Jones" -> "MJ")
    string initials = "AK";
    if (!string.IsNullOrWhiteSpace(fullName))
    {
        var nameParts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        // If they have a first and last name, grab the first letter of both
        if (nameParts.Length > 1)
        {
            initials = $"{nameParts[0][0]}{nameParts[nameParts.Length - 1][0]}".ToUpper();
        }
        // If it's just one word containing their username, grab the first two letters
        else if (nameParts.Length == 1)
        {
            initials = nameParts[0].Substring(0, Math.Min(2, nameParts[0].Length)).ToUpper();
        }
    }
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodeCircle</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CodeCircle.styles.css" asp-append-version="true" />
</head>
<body>
    <body>
        <!-- 1. We wrap everything in a master container -->
        <div class="app-container">

            <!-- 2. The Left Sidebar Navigation -->
            <aside class="sidebar">
                <div class="brand">
                    <span style="color: var(--brand-green);">●</span> CodeCircle <span class="beta-tag">beta</span>
                </div>

                <!-- Workspace Links -->
                <div class="sidebar-section">
                    <span class="section-title">WORKSPACE</span>
                    <a href="/Index" class="nav-item">☷ Live Feed</a>
                    <a href="/MyProjects" class="nav-item">📁 My Projects</a>
                    <a href="/CreateProject" class="nav-item">⊕ New Entry</a>
                </div>

                <!-- Community Links -->
                <div class="sidebar-section">
                    <span class="section-title">COMMUNITY</span>
                    <a href="/CelebrationWall" class="nav-item">★ Celebration Wall</a>
                </div>

                <div class="sidebar-spacer"></div>

                <!-- Profile Link at the bottom -->
                <div class="sidebar-section">
                    <span class="section-title">ACCOUNT</span>
                    <a href="/Profile" class="nav-item">👤 Profile</a>

                </div>
            </aside>

            <!-- 3. The Main Content Area (Everything to the right of the sidebar) -->
            <div class="main-content">

                <!-- A small top bar just for your Avatar -->
                <div class="top-bar">
                    <div class="user-avatar">@initials</div>
                </div>

                <!-- 4. This is where your page content (like Live Feed) actually loads! -->
                <main role="main">
                    @RenderBody()
                </main>

            </div>
        </div>

        <!-- Keep your scripts at the bottom -->
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>

</body>
</html>