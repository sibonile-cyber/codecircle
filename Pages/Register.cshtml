@page
@model CodeCircle.Pages.RegisterModel
@{
    ViewData["Title"] = "Create Account";
}

<style>
    .register-container {
        max-width: 500px;
        margin: 60px auto;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }
    
    /* 5-Step Tracker */
    .step-tracker {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
        position: relative;
    }
    .step-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        z-index: 2;
        background-color: var(--bg-dark);
    }
    .step-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 600;
        background-color: #030804;
        border: 1px solid #1c3d26;
        color: #5a665a;
        transition: all 0.3s;
    }
    .step-circle.active, .step-circle.completed {
        border: 2px solid #22c55e;
        color: #22c55e;
    }
    .step-text {
        font-size: 12px;
        font-weight: 500;
        color: #5a665a;
        transition: all 0.3s;
    }
    .step-text.active, .step-text.completed {
        color: #22c55e;
    }
    
    .step-line {
        position: relative;
        flex-grow: 1;
        height: 1px;
        background-color: #1c3d26;
        top: -10px;
        z-index: 1;
        transition: background-color 0.3s;
    }
    .step-line.active {
        background-color: #22c55e;
    }

    /* Main Form Container */
    .register-card {
        background-color: #050a06; 
        border: 1px solid #144021;
        border-radius: 12px;
        padding: 40px;
    }
    .auth-title {
        color: white;
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 8px;
    }
    .auth-subtitle {
        color: #6a7c6a;
        font-size: 14px;
        margin-bottom: 32px;
        line-height: 1.5;
    }

    /* Common Buttons & Assets */
    .social-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        gap: 12px;
        padding: 12px;
        background-color: transparent;
        border: 1px solid #1c3d26;
        border-radius: 8px;
        color: #e0f8e4;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        margin-bottom: 12px;
        transition: all 0.2s;
    }
    .social-btn:hover {
        background-color: rgba(34, 197, 94, 0.05);
        border-color: #2c5a38;
    }

    .divider {
        display: flex;
        align-items: center;
        text-align: center;
        color: #4b594b;
        font-size: 13px;
        margin: 24px 0;
    }
    .divider::before, .divider::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid #1c3d26;
    }
    .divider::before { margin-right: .75em; }
    .divider::after { margin-left: .75em; }

    /* Form Fields */
    .form-label {
        color: #6a7c6a;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 8px;
        display: block;
    }
    .form-control {
        width: 100%;
        background-color: #030804;
        border: 1px solid #164525;
        color: white;
        padding: 12px 14px;
        border-radius: 8px;
        font-size: 14px;
        transition: border-color 0.2s;
    }
    .form-control:focus {
        border-color: #22c55e;
        outline: none;
        box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.2);
    }
    .form-control::placeholder {
        color: #2c5938 !important;
        opacity: 1;
    }
    
    /* Input Wrapper logic for 'https://' prefix */
    .input-wrapper {
        display: flex;
        align-items: center;
        background-color: #030804;
        border: 1px solid #164525;
        border-radius: 8px;
        transition: border-color 0.2s;
    }
    .input-wrapper:focus-within {
        border-color: #22c55e;
        box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.2);
    }
    .input-prefix {
        color: #6a7c6a;
        font-size: 14px;
        padding-left: 14px;
    }
    .input-wrapper .form-control {
        border: none;
        box-shadow: none;
    }

    .pwd-helper {
        color: #4b594b;
        font-size: 11px;
        margin-top: 8px;
    }

    .terms-container {
        display: flex;
        align-items: center; 
        gap: 12px;
        margin: 24px 0;
    }
    .custom-checkbox {
        appearance: none;
        -webkit-appearance: none;
        width: 16px;
        height: 16px;
        background-color: white;
        border-radius: 3px;
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-shrink: 0;
    }
    .custom-checkbox:checked::after {
        content: "✔";
        color: #050a06;
        font-size: 11px;
        font-weight: bold;
    }
    .terms-text {
        color: #6a7c6a;
        font-size: 13px;
    }
    .terms-text a {
        color: #22c55e;
        text-decoration: none;
    }
    .terms-text a:hover {
        text-decoration: underline;
    }

    /* Step Navigation Buttons */
    .btn-submit {
        width: 100%;
        background-color: #1a7a2e;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
        transition: background-color 0.2s;
    }
    .btn-submit:hover {
        background-color: #1f8a3c;
    }

    /* Identity Color Pickers */
    .color-picker-circle {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        cursor: pointer;
        transition: transform 0.2s;
    }
    .color-picker-circle:hover {
        transform: scale(1.1);
    }
    .color-picker-circle.active {
        box-shadow: 0 0 0 2px white;
    }

    /* Skills Pill Tags */
    .skill-tag {
        background-color: transparent;
        border: 1px solid #1c3d26;
        color: #4b8c5a;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 4px;
    }
    .skill-tag:hover {
        border-color: #2c5a38;
        color: #5da86e;
    }
    .skill-tag.active {
        border-color: #22c55e;
        color: #22c55e;
        background-color: rgba(34, 197, 94, 0.05);
    }
</style>

<div class="register-container">
    
    <!-- 5 Step Progress Tracker -->
    <div class="step-tracker">
        <div class="step-item">
            <div id="circle-1" class="step-circle active">1</div>
            <div id="text-1" class="step-text active">Account</div>
        </div>
        <div id="line-1" class="step-line"></div>
        
        <div class="step-item">
            <div id="circle-2" class="step-circle inactive">2</div>
            <div id="text-2" class="step-text inactive">Identity</div>
        </div>
        <div id="line-2" class="step-line"></div>
        
        <div class="step-item">
            <div id="circle-3" class="step-circle inactive">3</div>
            <div id="text-3" class="step-text inactive">Skills</div>
        </div>
        <div id="line-3" class="step-line"></div>
        
        <div class="step-item">
            <div id="circle-4" class="step-circle inactive">4</div>
            <div id="text-4" class="step-text inactive">Links</div>
        </div>
        <div id="line-4" class="step-line"></div>
        
        <div class="step-item">
            <div id="circle-5" class="step-circle inactive">5</div>
            <div id="text-5" class="step-text inactive">Done</div>
        </div>
    </div>

    <!-- Main Registration Card -->
    <div class="register-card">
        
        <!-- ============================================== -->
        <!-- STEP 1: ACCOUNT (Visible Initially)            -->
        <!-- ============================================== -->
        <div id="step1">
            <h4 class="auth-title">Create your account</h4>
            <p class="auth-subtitle">Join developers who build in public. Free forever.</p>

            <button class="social-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Continue with Google
            </button>

            <button class="social-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.295 2.747-1.026 2.747-1.026.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12c0-5.523-4.477-10-10-10z"/>
                </svg>
                Continue with GitHub
            </button>

            <div class="divider">or sign up with email</div>

            <div class="row mb-3">
                <div class="col-6">
                    <label class="form-label">First name</label>
                    <input type="text" class="form-control" name="FirstName" placeholder="Alex" />
                </div>
                <div class="col-6">
                    <label class="form-label">Last name</label>
                    <input type="text" class="form-control" name="LastName" placeholder="Kim" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Email address</label>
                <input type="email" class="form-control" name="Email" placeholder="alex@example.com" />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" class="form-control" name="Password" placeholder="At least 8 characters" />
                <div class="pwd-helper">Enter a password to see strength</div>
            </div>

            <div class="terms-container">
                <input type="checkbox" class="custom-checkbox" />
                <div class="terms-text">
                    I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>
                </div>
            </div>

            <button type="button" id="btn-to-step2" class="btn-submit">Continue &rarr;</button>
        </div>


        <!-- ============================================== -->
        <!-- STEP 2: IDENTITY                               -->
        <!-- ============================================== -->
        <div id="step2" style="display: none;">
            
            <h4 class="auth-title">Set up your identity</h4>
            <p class="auth-subtitle">This is what others see on your profile and in the feed.</p>

            <div class="mb-4">
                <label class="form-label">Profile avatar</label>
                <div class="d-flex align-items-center gap-4">
                    <div style="width: 64px; height: 64px; border-radius: 50%; background-color: #1a4d29; border: 2px solid #22c55e; color: #3bda6d; display: flex; justify-content: center; align-items: center; font-size: 22px; font-weight: bold;">
                        AK
                    </div>
                    
                    <div>
                        <label style="color: #6a7c6a; font-size: 11px; margin-bottom: 8px; display: block;">Choose accent colour</label>
                        <div style="display: flex; flex-direction: row; gap: 10px;">
                            <div class="color-picker-circle active" style="background-color: #22c55e;"></div>
                            <div class="color-picker-circle" style="background-color: #3b82f6;"></div>
                            <div class="color-picker-circle" style="background-color: #06b6d4;"></div>
                            <div class="color-picker-circle" style="background-color: #f97316;"></div>
                            <div class="color-picker-circle" style="background-color: #8b5cf6;"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Username / handle</label>
                <input type="text" class="form-control" name="Username" placeholder="@@alexkim" />
                <div class="pwd-helper">Shown as @@handle in the feed</div>
            </div>

            <div class="mb-4">
                <label class="form-label d-flex justify-content-between">
                    <span>Bio</span>
                    <span style="font-size: 11px; color: #4b594b;">max 160 chars</span>
                </label>
                <textarea class="form-control" name="Bio" rows="3" placeholder="Full-stack dev building AI tooling in public..."></textarea>
            </div>

            <div class="mb-4">
                <label class="form-label">Location (optional)</label>
                <input type="text" class="form-control" name="Location" placeholder="e.g. Lagos, Berlin, Remote..." />
            </div>

            <div class="mb-4">
                <label class="form-label">Availability for collab</label>
                <select class="form-control" name="Availability" style="appearance: none; background-image: url('data:image/svg+xml;utf8,<svg fill=%22white%22 height=%2224%22 viewBox=%220 0 24 24%22 width=%2224%22 xmlns=%22http://www.w3.org/2000/svg%22><path d=%22M7 10l5 5 5-5z%22/></svg>'); background-repeat: no-repeat; background-position-x: 98%; background-position-y: center;">
                    <option>Open to collaboration</option>
                    <option>Not looking currently</option>
                </select>
            </div>

            <button type="button" id="btn-to-step3" class="btn-submit mb-3">Continue &rarr;</button>
            <button type="button" id="btn-back-step1" class="btn-submit" style="background-color: transparent; border: 1px solid #1c3d26; color: #6a7c6a;">&larr; Back</button>
            
        </div>


        <!-- ============================================== -->
        <!-- STEP 3: SKILLS & TECH STACK                      -->
        <!-- ============================================== -->
        <div id="step3" style="display: none;">
            
            <h4 class="auth-title">Skills & tech stack</h4>
            <p class="auth-subtitle">Select everything you work with. This powers collab matching and the "Seeking" filter.</p>

            <div class="mb-4">
                <label class="form-label">Languages</label>
                <div class="d-flex flex-wrap gap-2">
                    <button type="button" class="skill-tag">JavaScript</button>
                    <button type="button" class="skill-tag active">TypeScript</button>
                    <button type="button" class="skill-tag">Python</button>
                    <button type="button" class="skill-tag">Go</button>
                    <button type="button" class="skill-tag">Rust</button>
                    <button type="button" class="skill-tag">Java</button>
                    <button type="button" class="skill-tag">Ruby</button>
                    <button type="button" class="skill-tag">Swift</button>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Frameworks & tools</label>
                <div class="d-flex flex-wrap gap-2">
                    <button type="button" class="skill-tag active">React</button>
                    <button type="button" class="skill-tag active">Node.js</button>
                    <button type="button" class="skill-tag">Next.js</button>
                    <button type="button" class="skill-tag">Django</button>
                    <button type="button" class="skill-tag">FastAPI</button>
                    <button type="button" class="skill-tag">PostgreSQL</button>
                    <button type="button" class="skill-tag">Docker</button>
                    <button type="button" class="skill-tag">Supabase</button>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Interests / domains</label>
                <div class="d-flex flex-wrap gap-2">
                    <button type="button" class="skill-tag active">AI / LLM</button>
                    <button type="button" class="skill-tag active">SaaS</button>
                    <button type="button" class="skill-tag">Open source</button>
                    <button type="button" class="skill-tag">Fintech</button>
                    <button type="button" class="skill-tag">Health tech</button>
                    <button type="button" class="skill-tag">Dev tools</button>
                    <button type="button" class="skill-tag">Mobile</button>
                </div>
            </div>

            <div class="mb-4 mt-2">
                <label class="form-label">Role / what best describes you</label>
                <input type="text" class="form-control" name="Role" value="Full-stack developer" placeholder="e.g. Full-stack developer" />
            </div>

            <button type="button" id="btn-to-step4" class="btn-submit mb-3">Continue &rarr;</button>
            <button type="button" id="btn-back-step2" class="btn-submit" style="background-color: transparent; border: 1px solid #1c3d26; color: #6a7c6a;">&larr; Back</button>
            
        </div>
        
        <!-- ============================================== -->
        <!-- STEP 4: YOUR LINKS                             -->
        <!-- ============================================== -->
        <div id="step4" style="display: none;">
            
            <h4 class="auth-title">Your links</h4>
            <p class="auth-subtitle">Add your online presence &mdash; these appear on your profile and build trust in the community.</p>

            <div class="mb-4">
                <label class="form-label">Personal website</label>
                <div class="input-wrapper">
                    <span class="input-prefix">https://</span>
                    <input type="text" class="form-control" name="Website" placeholder="yoursite.dev" />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">GitHub username</label>
                <input type="text" class="form-control" name="GithubUrl" placeholder="github.com/username" />
            </div>

            <div class="mb-4">
                <label class="form-label">LinkedIn</label>
                <input type="text" class="form-control" name="LinkedInUrl" placeholder="linkedin.com/in/username" required />
            </div>

            <div style="background-color: rgba(34, 197, 94, 0.05); border: 1px solid #1c3d26; border-radius: 8px; padding: 16px; margin-bottom: 24px;">
                <p style="color: #6a7c6a; font-size: 13px; margin: 0; line-height: 1.5;">
                    <span style="color: #22c55e; font-weight: 600;">Profile preview:</span> Your links appear as icon buttons on your public profile. At least one is recommended for collab credibility.
                </p>
            </div>

            <button type="button" id="btn-to-step5" class="btn-submit mb-3">Finish setup &rarr;</button>
            <button type="button" id="btn-back-step3" class="btn-submit" style="background-color: transparent; border: 1px solid #1c3d26; color: #6a7c6a;">&larr; Back</button>
            
        </div>
        
        <!-- ============================================== -->
        <!-- STEP 5: DONE                                   -->
        <!-- ============================================== -->
        <div id="step5" style="display: none; text-align: center; padding: 40px 0;">
            <div style="width: 80px; height: 80px; border-radius: 50%; background-color: rgba(34, 197, 94, 0.1); color: #22c55e; display: flex; align-items: center; justify-content: center; font-size: 40px; margin: 0 auto 24px;">&#10003;</div>
            <h4 class="auth-title">You're all set!</h4>
            <p class="auth-subtitle mb-4">Your CodeCircle profile is entirely generated and ready.</p>
            <a href="/Index" class="btn-submit" style="display: inline-block; text-decoration: none; width: auto; padding: 12px 40px;">Go to Live Feed &rarr;</a>
            <br/><br/>
            <button type="button" id="btn-back-step4" class="btn-submit" style="background-color: transparent; width: auto; border: 1px solid #1c3d26; color: #6a7c6a; padding: 12px 32px;">&larr; Back to Links</button>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            
            let currentStep = 1;
            const totalSteps = 5;

            function updateUI() {
                for (let i = 1; i <= totalSteps; i++) {
                    let panel = document.getElementById("step" + i);
                    if (panel) {
                        panel.style.display = (i === currentStep) ? "block" : "none";
                    }
                }

                for (let i = 1; i <= totalSteps; i++) {
                    let circle = document.getElementById("circle-" + i);
                    let text = document.getElementById("text-" + i);
                    let line = document.getElementById("line-" + i);
                    
                    if (!circle || !text) continue;

                    if (i < currentStep) {
                        circle.className = "step-circle completed";
                        circle.innerHTML = "&#10003;"; 
                        text.className = "step-text completed";
                        if (line) line.className = "step-line active";
                    } else if (i === currentStep) {
                        circle.className = "step-circle active";
                        circle.innerHTML = i; 
                        text.className = "step-text active";
                        if (line) line.className = "step-line";
                    } else {
                        circle.className = "step-circle inactive";
                        circle.innerHTML = i;
                        text.className = "step-text inactive";
                        if (line) line.className = "step-line";
                    }
                }
            }

            // STEP 1
            const btnToStep2 = document.getElementById("btn-to-step2");
            if (btnToStep2) btnToStep2.addEventListener("click", () => { currentStep = 2; updateUI(); });

            // STEP 2
            const btnBackStep1 = document.getElementById("btn-back-step1");
            if (btnBackStep1) btnBackStep1.addEventListener("click", () => { currentStep = 1; updateUI(); });
            const btnToStep3 = document.getElementById("btn-to-step3");
            if (btnToStep3) btnToStep3.addEventListener("click", () => { currentStep = 3; updateUI(); });

            // STEP 3
            const btnBackStep2 = document.getElementById("btn-back-step2");
            if (btnBackStep2) btnBackStep2.addEventListener("click", () => { currentStep = 2; updateUI(); });
            const btnToStep4 = document.getElementById("btn-to-step4");
            if (btnToStep4) btnToStep4.addEventListener("click", () => { currentStep = 4; updateUI(); });

            // STEP 4
            const btnBackStep3 = document.getElementById("btn-back-step3");
            if (btnBackStep3) btnBackStep3.addEventListener("click", () => { currentStep = 3; updateUI(); });
            const btnToStep5 = document.getElementById("btn-to-step5");
            if (btnToStep5) btnToStep5.addEventListener("click", () => { currentStep = 5; updateUI(); });

            // STEP 5 (Done placeholder -> can go back if they want)
            const btnBackStep4 = document.getElementById("btn-back-step4");
            if (btnBackStep4) btnBackStep4.addEventListener("click", () => { currentStep = 4; updateUI(); });


            // Interactive components
            const colorPickers = document.querySelectorAll(".color-picker-circle");
            colorPickers.forEach(picker => {
                picker.addEventListener("click", function() {
                    colorPickers.forEach(p => p.classList.remove("active"));
                    this.classList.add("active");
                });
            });

            const skillTags = document.querySelectorAll(".skill-tag");
            skillTags.forEach(tag => {
                tag.addEventListener("click", function() {
                    this.classList.toggle("active");
                });
            });

            updateUI();
        });
    </script>
}
