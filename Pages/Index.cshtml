@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="dashboard-grid">

    <!-- Central Feed Area -->
    <div class="feed-column">
        <div class="feed-header">
            <h1>Developer Activity Feed</h1>
            <a href="/CreateProject" class="btn-primary">Create Project</a>
        </div>

       
        <div class="glass-card">
            
            @foreach (var project in Model.Projects)
            {
                <div class="glass-card">

                    <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 20px;">
                        <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--accent-green); color: #111815; display: flex; justify-content: center; align-items: center; font-weight: bold;">
                            👨‍💻
                        </div>
                        <div style="flex-grow: 1;">
                            <span style="font-weight: bold; color: white;">A Developer</span>
                            <span style="background: rgba(103, 214, 113, 0.2); color: var(--accent-green); padding: 4px 10px; border-radius: 12px; font-size: 12px; margin-left: 10px; font-weight: bold;">
                                @project.Stage
                            </span>
                        </div>
                    </div>

                    <!-- Main Content -->
                    <h2 style="font-size: 20px; font-weight: 700; margin-bottom: 10px;">@project.Title</h2>
                    <p style="color: var(--text-muted); line-height: 1.6; margin-bottom: 20px;">@project.Description</p>

                    @if (!string.IsNullOrEmpty(project.SupportRequired))
                    {
                        <p style="color: var(--text-main); font-size: 14px; margin-bottom: 30px;">
                            <strong style="color: var(--accent-green);">Support Needed:</strong> @project.SupportRequired
                        </p>
                    }

                    <!-- Action Buttons -->
                    <div style="display: flex; gap: 15px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.1);">
                        <button style="background: rgba(255,255,255,0.05); color: white; padding: 8px 16px; border-radius: 6px; font-size: 14px; font-weight: 600;">💬 Comment</button>
                        <button style="background: rgba(255,255,255,0.05); color: white; padding: 8px 16px; border-radius: 6px; font-size: 14px; font-weight: 600;">✋ Raise Hand</button>
                    </div>

                </div>
            }

        </div>
    </div>

    <!-- Right Side Widgets Area -->
    <div class="widget-column">

        <div class="glass-card">
            <h3 style="font-size: 16px; margin-bottom: 15px;">Trending Projects <span style="float:right; color: var(--text-muted);">...</span></h3>
            <p style="color: var(--text-muted); font-size: 14px;">Coming soon</p>
        </div>

        <div class="glass-card">
            <h3 style="font-size: 16px; margin-bottom: 15px;">Active Developers <span style="float:right; color: var(--text-muted);">...</span></h3>
            <p style="color: var(--text-muted); font-size: 14px;">Coming soon</p>
        </div>

        <div class="glass-card">
            <h3 style="font-size: 16px; margin-bottom: 15px;">Quick Stats <span style="float:right; color: var(--text-muted);">...</span></h3>
            <div style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 8px;">
                <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 10px;">Projects: <strong>0</strong></p>
                <p style="color: var(--text-muted); font-size: 14px; margin:0;">Completed: <strong>0</strong></p>
            </div>
            <div class="celebration-feed">
                @if (Model.Celebrations != null && Model.Celebrations.Any())
                {
                    foreach (var win in Model.Celebrations)
                    {
                        <div class="celebration-item flex-row">
                            <div class="avatar bg-primary">@win.DeveloperInitials</div>

                            <div class="celebration-content">
                                <strong>@win.DeveloperName</strong>
                                <span class="action-text">@win.ActionText</span>
                                <p class="project-title">@win.ProjectTitle</p>

                                <!-- Display the image if one was uploaded! -->
                                @if (!string.IsNullOrEmpty(win.ImagePath))
                                {
                                    <img src="@win.ImagePath" alt="Win Image" style="max-width: 100%; border-radius: 8px; margin-top: 8px;" />
                                }

                                <!-- Formats date to look like "Oct 12" -->
                                <small class="time-ago">@win.CreatedAt.ToString("MMM dd")</small>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p style="color: #8B949E; text-align: center; margin-top: 20px;">No wins yet. Be the first to post!</p>
                }
            </div>


                    <!-- Celebration Item 2 -->
                    <div class="celebration-item flex-row">
                        <div class="avatar bg-primary">MJ</div>
                        <div class="celebration-content">
                            <strong>Mark J.</strong>
                            <span class="action-text">squashed a bug</span>
                            <p class="project-title">Resolved DB Timeout Issue</p>
                            <small class="time-ago">5 hours ago</small>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>

</div>
