@page
@model IndexModel
@{
    ViewData["Title"] = "Live Feed";
}

<style>
    .feed-action-btn {
        cursor: pointer;
        color: #999;
        font-size: 13px;
        display: flex;
        align-items: center;
        padding: 6px 12px;
        border-radius: 6px;
        margin-left: -12px;
        transition: all 0.2s;
        border: 1px solid transparent;
        text-decoration: none;
    }
    .feed-action-btn:hover {
        color: #22c55e;
        background-color: rgba(34, 197, 94, 0.05);
    }

    .collab-modal {
        background-color: #030804;
        border: 1px solid #1c3d26;
        border-radius: 12px;
        width: 100%;
        max-width: 550px;
        padding: 24px;
        color: white;
        max-height: 90vh;
        overflow-y: auto;
    }

    .collab-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 24px;
    }

    .collab-modal-title {
        font-size: 20px;
        font-weight: 700;
        margin: 0 0 4px;
    }

    .collab-modal-subtitle {
        color: #6a7c6a;
        font-size: 13px;
        margin: 0;
    }

    .close-modal-btn {
        background: transparent;
        border: 1px solid #1c3d26;
        color: #5a665a;
        border-radius: 6px;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.2s;
    }

        .close-modal-btn:hover {
            background-color: #144021;
            color: white;
        }

    /* Custom Input Styles inside Modal */
    .project-radio-card {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px;
        border: 1px solid #1c3d26;
        border-radius: 8px;
        margin-bottom: 12px;
        cursor: pointer;
        background-color: transparent;
        transition: all 0.2s;
    }

        .project-radio-card.active {
            border-color: #22c55e;
            background-color: rgba(34, 197, 94, 0.05);
        }

    .custom-radio {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        border: 2px solid #1c3d26;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .project-radio-card.active .custom-radio {
        border-color: #22c55e;
    }

        .project-radio-card.active .custom-radio::after {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background-color: #22c55e;
        }

    .project-title {
        font-weight: 600;
        font-size: 14px;
        margin: 0 0 4px;
        color: white;
    }

    .project-meta {
        color: #6a7c6a;
        font-size: 12px;
        margin: 0;
    }

    .modal-label {
        display: block;
        color: #6a7c6a;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 10px;
    }

    .dark-select {
        width: 100%;
        background-color: #030804;
        border: 1px solid #1c3d26;
        color: white;
        padding: 12px;
        border-radius: 8px;
        font-size: 14px;
        appearance: none;
        background-image: url('data:image/svg+xml;utf8,<svg fill="%23ffffff" height="24" viewBox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg"><path d="M7 10l5 5 5-5z"/></svg>');
        background-repeat: no-repeat;
        background-position: right 10px center;
    }

    /* Button Aesthetics */
    .custom-filter-btn {
        background-color: transparent !important;
        border: 1px solid #165228 !important;
        color: #3bda6d !important;
        padding: 8px 18px !important;
        border-radius: 8px !important;
        font-size: 14.5px !important;
        font-weight: 500 !important;
        cursor: pointer;
        transition: all 0.2s;
    }

        .custom-filter-btn:hover {
            background-color: rgba(34, 197, 94, 0.1) !important;
        }

    .custom-new-btn {
        background-color: #1f8a3c !important;
        color: #e0f8e4 !important;
        border: none !important;
        padding: 8px 24px !important;
        border-radius: 8px !important;
        font-size: 14.5px !important;
        font-weight: 600 !important;
        text-decoration: none !important;
        display: inline-flex !important;
        align-items: center !important;
        justify-content: center !important;
        transition: all 0.2s;
    }

        .custom-new-btn:hover {
            background-color: #1a6b26 !important;
            color: white !important;
        }

    /* Target Filter Panel Unselected Tags */
    .filter-tag {
        background-color: transparent;
        border: 1px solid #1c3d26;
        color: #4b8c5a;
        padding: 6px 18px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

        .filter-tag:hover {
            border-color: #2c5a38;
            color: #5da86e;
        }

        .filter-tag.active {
            border-color: #22c55e;
            color: #22c55e;
            background-color: rgba(34, 197, 94, 0.05);
        }

    /* The active display pills that appear underneath the Live Feed header */
    .active-display-pill {
        display: inline-flex;
        align-items: center;
        border: 1px solid #22c55e;
        color: #22c55e;
        background-color: rgba(34, 197, 94, 0.05);
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

        .active-display-pill .remove-pill {
            margin-left: 6px;
            cursor: pointer;
            color: #22c55e;
            opacity: 0.6;
            font-size: 14px;
            transition: opacity 0.2s;
        }

            .active-display-pill .remove-pill:hover {
                opacity: 1;
            }
</style>

<!-- ============================================================== -->
<!-- THE 2-COLUMN SPLIT FEED                                        -->
<!-- ============================================================== -->
<div class="feed-layout">

    <div class="feed-main" style="min-width: 0;">

        <!-- 1. Live Feed Header Text (With the powerful new Active Row!) -->
        <div class="mb-4 mt-3">
            <h3 class="page-title">Live Feed</h3>
            <p class="page-subtitle">What devs are building right now</p>

            <!-- JS dynamically injects the active pills here! -->
            <div id="active-filters-container" class="align-items-center gap-2 mt-4" style="display: none;">
                <span style="color: #6a7c6a; font-size: 13px;">Active:</span>
                <div id="active-filters-list" class="d-flex flex-wrap gap-2"></div>
            </div>
        </div>

        <!-- 2. THE BIG FILTER PANEL -->
        <div id="filter-panel" class="mb-5" style="display: none; border: 1px solid #144021; padding: 24px; border-radius: 12px; background-color: #030804; width: 100%;">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="text-white mb-0" style="font-weight: bold; font-size: 15px;">Filter feed</h5>
                <span id="close-filter-btn" style="color: #6a7c6a; cursor: pointer; font-size: 16px; font-weight: bold;">&#10005;</span>
            </div>

            <div class="mb-4">
                <div style="font-size: 11px; font-weight: 600; letter-spacing: 1px; color: #5a665a; margin-bottom: 12px;">STAGE</div>
                <div class="d-flex flex-wrap gap-2">
                    <button class="filter-tag">Ideating</button>
                    <button class="filter-tag">Building</button>
                    <button class="filter-tag">Launching</button>
                    <button class="filter-tag">Completed</button>
                </div>
            </div>

            <div class="mb-4">
                <div style="font-size: 11px; font-weight: 600; letter-spacing: 1px; color: #5a665a; margin-bottom: 12px;">SUPPORT NEEDED</div>
                <div class="d-flex flex-wrap gap-2">
                    <button class="filter-tag">LLM engineer</button>
                    <button class="filter-tag">Designer</button>
                    <button class="filter-tag">Backend dev</button>
                    <button class="filter-tag">Marketing</button>
                    <button class="filter-tag">Any role</button>
                </div>
            </div>

            <div class="mb-4">
                <div style="font-size: 11px; font-weight: 600; letter-spacing: 1px; color: #5a665a; margin-bottom: 12px;">TOPIC / TECH</div>
                <div class="d-flex flex-wrap gap-2">
                    <button class="filter-tag">AI / LLM</button>
                    <button class="filter-tag">SaaS</button>
                    <button class="filter-tag">Developer tools</button>
                    <button class="filter-tag">Health tech</button>
                    <button class="filter-tag">Fintech</button>
                    <button class="filter-tag">Open source</button>
                </div>
            </div>

            <div class="mb-4">
                <div style="font-size: 11px; font-weight: 600; letter-spacing: 1px; color: #5a665a; margin-bottom: 12px;">SORT BY</div>
                <div class="d-flex flex-wrap gap-2">
                    <button class="filter-tag">Latest</button>
                    <button class="filter-tag">Most active</button>
                    <button class="filter-tag">Most collab requests</button>
                    <button class="filter-tag">Near completion</button>
                </div>
            </div>

            <hr style="border-color: #143521; margin: 30px 0; border-width: 1px; opacity: 1;">

            <div class="d-flex gap-3">
                <button id="clear-filters-btn" class="btn" style="color: #6a7c6a; border: 1px solid #1c3d26; padding: 10px 32px; font-size: 13px; border-radius: 8px; font-weight: 500; background-color: transparent; transition: all 0.2s;">Clear all</button>
                <button id="apply-filters-btn" class="btn flex-grow-1" style="font-weight: 600; font-size: 14px; padding: 10px; border-radius: 8px; border: none; background-color: #1f8a3c; color: white; transition: all 0.2s;">Apply filters</button>
            </div>
        </div>

        <!-- 3. The Feed Posts loop -->
        @{ var projectIndex = 0; }
        @foreach (var project in Model.LiveFeedProjects)
        {
            <div class="dashboard-card mb-4 @(projectIndex > 0 ? "depth-fade" : "")" style="overflow: hidden; word-wrap: break-word;">
                
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div class="d-flex gap-3 align-items-start">

                        <div class="wall-avatar mt-1" style="width: 42px; height: 42px; font-size: 16px; background-color: #1a3320; color: var(--brand-green); border: 1px solid #22c55e; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            @(string.IsNullOrEmpty(project.DeveloperId) ? "AK" : project.DeveloperId.Substring(0, Math.Min(2, project.DeveloperId.Length)).ToUpper())
                        </div>

                        <div class="d-flex flex-column">
                            <div style="color: white; font-weight: bold; font-size: 15px;">
                                @(string.IsNullOrEmpty(project.DeveloperId) ? "Alex Kim" : project.DeveloperId)
                                <span class="text-muted" style="font-weight: normal; font-size: 13px;">— you</span>
                            </div>
                            <div class="text-muted" style="font-size: 12px; margin-bottom: 8px;">2 minutes ago</div>

                            <div>
                                <span class="badge-building">
                                    <span class="live-dot"></span>
                                    @(string.IsNullOrEmpty(project.Stage) ? "Actively building" : project.Stage)
                                </span>
                            </div>
                        </div>

                    </div>
                </div>

                <h5 style="color: #22c55e; font-size: 16px; margin-bottom: 16px; font-weight: 500;">
                    @project.Title
                </h5>

                <div style="font-size: 14px; color: #ccc; margin-bottom: 24px; padding-left: 4px;">
                    <span class="milestone-chip">✓ Milestone: Auth system shipped — JWT + refresh tokens done!</span>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between text-muted" style="font-size: 12px; margin-bottom: 8px;">
                        <span>Overall progress</span>
                        <span>42%</span>
                    </div>
                    <div class="progress-track">
                        <div class="progress-fill" style="width: 42%;"></div>
                    </div>
                </div>

                <p style="color: #ccc; font-size: 14px; line-height: 1.6; margin-bottom: 24px;">
                    @project.Description
                </p>

                <div class="d-flex gap-4" style="margin-left: 12px;">
                    <button class="feed-action-btn toggle-comments-btn" style="background: transparent;">
                        <span style="color: white; margin-right: 8px; font-size: 16px;">💬</span> <span class="comment-count-text">4 comments</span>
                    </button>
                    <a href="/RequestCollab" class="feed-action-btn">
                        <span style="margin-right: 8px; font-size: 16px;">👋</span> Request collab
                    </a>
                </div>

                <!-- Interactive Comments Section -->
                <div class="comments-section mt-4" style="display: none; border-top: 1px solid #14532d; padding-top: 16px; margin-left: 12px; margin-right: 12px;">
                    <div class="comments-list">
                        <!-- Default mock comment -->
                        <div class="d-flex mb-3">
                            <div class="wall-avatar" style="width: 32px; height: 32px; font-size: 11px; background-color: #1a3320; color: #22c55e; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-right: 12px;">SJ</div>
                            <div>
                                <div style="font-size: 13px; font-weight: bold; color: white;">Sarah Jones <span style="font-weight: normal; color: #6a7c6a; font-size: 11px; margin-left: 6px;">1 hr ago</span></div>
                                <div style="font-size: 13px; color: #ccc; margin-top: 4px;">This looks amazing! Keep it up.</div>
                                <div class="d-flex gap-3 mt-2">
                                    <span class="comment-react-btn" data-count="2" style="color: #6a7c6a; font-size: 12px; cursor: pointer; transition: 0.2s;">👍 <span class="react-count">2</span></span>
                                    <span style="color: #6a7c6a; font-size: 12px; cursor: pointer;">Reply</span>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex mb-3">
                            <div class="wall-avatar" style="width: 32px; height: 32px; font-size: 11px; background-color: #1a2e33; color: #3b82f6; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-right: 12px;">DO</div>
                            <div>
                                <div style="font-size: 13px; font-weight: bold; color: white;">Dana Ortiz <span style="font-weight: normal; color: #6a7c6a; font-size: 11px; margin-left: 6px;">2 hrs ago</span></div>
                                <div style="font-size: 13px; color: #ccc; margin-top: 4px;">Very cool progress! Would love to chat about the backend.</div>
                                <div class="d-flex gap-3 mt-2">
                                    <span class="comment-react-btn" data-count="5" style="color: #6a7c6a; font-size: 12px; cursor: pointer; transition: 0.2s;">👍 <span class="react-count">5</span></span>
                                    <span style="color: #6a7c6a; font-size: 12px; cursor: pointer;">Reply</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Add Comment input -->
                    <div class="d-flex align-items-center mt-3 pt-3" style="border-top: 1px dashed #14532d;">
                        <div class="wall-avatar" style="width: 32px; height: 32px; font-size: 11px; background-color: #1a3320; color: #22c55e; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-right: 12px;">AK</div>
                        <input type="text" class="comment-input" placeholder="Write a comment..." style="flex-grow: 1; min-width: 0; background-color: #030804; border: 1px solid #1c3d26; color: white; padding: 8px 16px; border-radius: 20px; font-size: 13px; outline: none;" onfocus="this.style.borderColor='#22c55e'" onblur="this.style.borderColor='#1c3d26'" />
                        <button class="comment-submit-btn" style="background-color: #1f8a3c; color: white; border: none; padding: 8px 16px; border-radius: 20px; font-size: 13px; font-weight: bold; margin-left: 8px; cursor: pointer; transition: 0.2s;" onmouseover="this.style.backgroundColor='#166b2d'" onmouseout="this.style.backgroundColor='#1f8a3c'">Post</button>
                    </div>
                </div>

            </div>
            projectIndex++;
        }

    </div>

    <!-- RIGHT COLUMN -->
    <div class="feed-widgets" style="min-width: 0;">

        <!-- Static Buttons -->
        <div class="d-flex justify-content-start gap-3 mb-4 mt-3">
            <button id="toggle-filter-btn" class="custom-filter-btn d-flex align-items-center gap-2">
                <svg width="14" height="12" viewBox="0 0 14 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 1.5H13M3 6H11M5.5 10.5H8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
                Filter
                <!-- The badge that wakes up when clicked! -->
                <span id="filter-badge" style="background-color: #22c55e; color: #000; border-radius: 50%; width: 22px; height: 22px; font-size: 11.5px; font-weight: bold; display: none; align-items: center; justify-content: center; line-height: 1;">0</span>
            </button>
            <a href="/CreateProject" class="custom-new-btn">+ New Entry</a>
        </div>

        <!-- Widget 1: Trending Topics -->
        <div class="dashboard-card mb-0" style="padding: 24px; border-radius: 12px; background-color: #050a06; border: 1px solid #14532d;">
            <h6 class="text-muted mb-4" style="font-size: 11px; font-weight: 600; letter-spacing: 1px;">TRENDING TOPICS</h6>

            <div class="d-flex justify-content-between mb-3" style="font-size: 13px;">
                <div class="text-white"><span style="color: #3b82f6; margin-right: 8px;">●</span> AI / LLM</div>
                <div class="text-muted">24 projects</div>
            </div>
            <div class="d-flex justify-content-between mb-3" style="font-size: 13px;">
                <div class="text-white"><span style="color: #22c55e; margin-right: 8px;">●</span> SaaS</div>
                <div class="text-muted">18 projects</div>
            </div>
            <div class="d-flex justify-content-between mb-3" style="font-size: 13px;">
                <div class="text-white"><span style="color: #eab308; margin-right: 8px;">●</span> Developer tools</div>
                <div class="text-muted">15 projects</div>
            </div>
            <div class="d-flex justify-content-between mb-3" style="font-size: 13px;">
                <div class="text-white"><span style="color: #06b6d4; margin-right: 8px;">●</span> Health tech</div>
                <div class="text-muted">9 projects</div>
            </div>
            <div class="d-flex justify-content-between" style="font-size: 13px;">
                <div class="text-white"><span style="color: #f97316; margin-right: 8px;">●</span> Fintech</div>
                <div class="text-muted">7 projects</div>
            </div>
        </div>

        <!-- Widget 2: Online Now -->
        <div class="dashboard-card mt-4 mb-0" style="padding: 24px; border-radius: 12px; background-color: #050a06; border: 1px solid #14532d;">
            <h6 class="text-muted mb-4" style="font-size: 11px; font-weight: 600; letter-spacing: 1px;">ONLINE NOW</h6>

            <div class="d-flex align-items-center mb-3 text-white" style="font-size: 13px;">
                <span style="color: #22c55e; margin-right: 8px;">●</span> Sara Reeves
            </div>
            <div class="d-flex align-items-center mb-3 text-white" style="font-size: 13px;">
                <span style="color: #22c55e; margin-right: 8px;">●</span> Marcus Jones
            </div>
            <div class="d-flex align-items-center mb-3 text-white" style="font-size: 13px;">
                <span style="color: #22c55e; margin-right: 8px;">●</span> Priya Nair
            </div>
            <div class="d-flex align-items-center mb-3 text-white" style="font-size: 13px;">
                <span style="color: #22c55e; margin-right: 8px;">●</span> Tom Li
            </div>
            <div class="d-flex align-items-center text-white" style="font-size: 13px;">
                <span style="color: #22c55e; margin-right: 8px;">●</span> Dana Ortiz
            </div>
        </div>

        <!-- Widget 3: Seeking Collaborators -->
        <div class="dashboard-card mt-4 mb-0" style="padding: 24px; border-radius: 12px; background-color: #050a06; border: 1px solid #14532d;">
            <h6 class="text-muted mb-4" style="font-size: 11px; font-weight: 600; letter-spacing: 1px;">SEEKING COLLABORATORS</h6>

            <div class="mb-3">
                <div class="text-white" style="font-weight: bold; font-size: 14px;">DevFlow</div>
                <div class="text-muted" style="font-size: 12px;">Needs: LLM engineer</div>
            </div>
            <div class="mb-3">
                <div class="text-white" style="font-weight: bold; font-size: 14px;">HealthLog</div>
                <div class="text-muted" style="font-size: 12px;">Needs: UI/UX designer</div>
            </div>
            <div>
                <div class="text-white" style="font-weight: bold; font-size: 14px;">CodeBuddy</div>
                <div class="text-muted" style="font-size: 12px;">Needs: Backend dev</div>
            </div>
        </div>

    </div>
</div>


<!-- ============================================================== -->
<!-- ALL FRONTEND LOGIC (Interactive Filter Core Engine)            -->
<!-- ============================================================== -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const toggleBtn = document.getElementById("toggle-filter-btn");
        const closeBtn = document.getElementById("close-filter-btn");
        const filterPanel = document.getElementById("filter-panel");
        const filterTags = document.querySelectorAll(".filter-tag");
        const filterBadge = document.getElementById("filter-badge");

        const clearBtn = document.getElementById("clear-filters-btn");
        const applyBtn = document.getElementById("apply-filters-btn");

        const activeContainer = document.getElementById("active-filters-container");
        const activeList = document.getElementById("active-filters-list");

       
        if (toggleBtn && filterPanel) {
            toggleBtn.addEventListener("click", function () {
                filterPanel.style.display = filterPanel.style.display === "none" ? "block" : "none";
            });
        }

        
        if (closeBtn && filterPanel) {
            closeBtn.addEventListener("click", function () {
                filterPanel.style.display = "none";
            });
        }

        
        function updateBadge() {
            if (!filterBadge) return;
            const activeCount = document.querySelectorAll("#filter-panel .filter-tag.active").length;
            if (activeCount > 0) {
                filterBadge.textContent = activeCount;
                filterBadge.style.display = "flex";
            } else {
                filterBadge.style.display = "none";
            }
        }

       
        function buildActiveTagsRow() {
            if (!activeList || !activeContainer) return;

           
            activeList.innerHTML = "";
            const activeTags = document.querySelectorAll("#filter-panel .filter-tag.active");

            if (activeTags.length === 0) {
              
                activeContainer.style.display = "none";
                return;
            }

            
            activeContainer.style.display = "flex";

            activeTags.forEach(tag => {
                const tagText = tag.textContent.trim();

                const pill = document.createElement("span");
                pill.className = "active-display-pill";
                pill.innerHTML = `${tagText} <span class="remove-pill">&times;</span>`;

                
                pill.querySelector(".remove-pill").addEventListener("click", function () {
                  
                    tag.classList.remove("active");
                    updateBadge();
                    buildActiveTagsRow();
                });

                activeList.appendChild(pill);
            });
        }

        
        filterTags.forEach(tag => {
            tag.addEventListener("click", function () {
                this.classList.toggle("active");
                updateBadge();
            });
        });

        
        if (clearBtn) {
            clearBtn.addEventListener("click", function () {
                filterTags.forEach(tag => tag.classList.remove("active"));
                updateBadge();
                buildActiveTagsRow();
            });
        }

        
        if (applyBtn && filterPanel) {
            applyBtn.addEventListener("click", function () {
               
                filterPanel.style.display = "none";
                buildActiveTagsRow();
            });
        }

        // ==========================================
        // Comment Section Interactivity Logic
        // ==========================================
        
        // 1. Toggle Comments Section
        document.querySelectorAll('.toggle-comments-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                const card = e.target.closest('.dashboard-card');
                const section = card.querySelector('.comments-section');
                if(section.style.display === 'none') {
                    section.style.display = 'block';
                } else {
                    section.style.display = 'none';
                }
            });
        });

        // 2. React to Comments
        document.body.addEventListener('click', function(e) {
            const reactBtn = e.target.closest('.comment-react-btn');
            if(reactBtn) {
                // simple toggle reaction logic
                const isReacted = reactBtn.dataset.reacted === 'true';
                let count = parseInt(reactBtn.dataset.count || 0);

                if(!isReacted) {
                    count++;
                    reactBtn.dataset.reacted = 'true';
                    reactBtn.style.color = '#22c55e';
                } else {
                    count--;
                    reactBtn.dataset.reacted = 'false';
                    reactBtn.style.color = '#6a7c6a';
                }
                reactBtn.dataset.count = count;
                reactBtn.querySelector('.react-count').textContent = count;
            }
        });

        // 3. Post a new comment
        document.querySelectorAll('.comment-submit-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                const section = e.target.closest('.comments-section');
                const input = section.querySelector('.comment-input');
                const list = section.querySelector('.comments-list');
                
                const text = input.value.trim();
                if(text !== '') {
                    // Create new comment element matching styling mapping to AK user
                    const html = `
                        <div class="d-flex mb-3">
                            <div class="wall-avatar" style="width: 32px; height: 32px; font-size: 11px; background-color: #1a3320; color: #22c55e; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-right: 12px;">AK</div>
                            <div>
                                <div style="font-size: 13px; font-weight: bold; color: white;">Alex Kim <span style="font-weight: normal; color: #22c55e; font-size: 11px; margin-left: 6px;">Just now</span></div>
                                <div style="font-size: 13px; color: #ccc; margin-top: 4px;">${text.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</div>
                                <div class="d-flex gap-3 mt-2">
                                    <span class="comment-react-btn" data-count="0" style="color: #6a7c6a; font-size: 12px; cursor: pointer; transition: 0.2s;">👍 <span class="react-count">0</span></span>
                                    <span style="color: #6a7c6a; font-size: 12px; cursor: pointer;">Reply</span>
                                </div>
                            </div>
                        </div>
                    `;
                    list.insertAdjacentHTML('beforeend', html);
                    input.value = '';

                    // Update count
                    const card = section.closest('.dashboard-card');
                    const countText = card.querySelector('.comment-count-text');
                    let currentCount = parseInt(countText.textContent);
                    if(isNaN(currentCount)) currentCount = 4; // base
                    countText.textContent = (currentCount + 1) + " comments";
                }
            });
        });

        // allow 'Enter' key mapping for commenting
        document.querySelectorAll('.comment-input').forEach(input => {
            input.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    input.closest('.comments-section').querySelector('.comment-submit-btn').click();
                }
            });
        });

    });

</script>
