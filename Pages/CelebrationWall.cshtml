@page
@model CodeCircle.Pages.CelebrationWallModel
@{
    ViewData["Title"] = "Celebration Wall";
}

<!-- Massive Center Header -->
<div class="text-center mb-5 mt-4">
    <h2 class="mb-2">Celebration Wall</h2>
    <p class="text-muted mb-4">Developers who shipped and built in public — legends.</p>
    <span class="badge-building py-2 px-4" style="font-size: 14px;">✦ 128 projects shipped</span>
</div>

<!-- Flexbox Grid for the Cards -->
<div class="celebration-grid">

    <!-- Marcus: Blue Accent Card -->
    <div class="dashboard-card celebration-card border-blue">
        <!-- We use 'mx-auto' to center the avatar inline -->
        <div class="wall-avatar mx-auto mb-3" style="background-color: #0d1e36; color: #3b82f6;">MJ</div>
        <h5 class="mb-0 text-white">Marcus Jones</h5>
        <div class="text-green mb-3" style="font-size: 14px;">QuickInvoice</div>
        <p class="text-muted" style="font-size: 13px;">Freelancer billing SaaS — 50+ paying users in month 1</p>
    </div>

    <!-- Priya: Green Accent Card -->
    <div class="dashboard-card celebration-card border-green">
        <div class="wall-avatar mx-auto mb-3" style="background-color: #1a3320; color: var(--brand-green);">PL</div>
        <h5 class="mb-0 text-white">Priya L.</h5>
        <div class="text-green mb-3" style="font-size: 14px;">FocusFlow</div>
        <p class="text-muted" style="font-size: 13px;">Pomodoro + task manager — featured on Product Hunt</p>
    </div>

    <!-- Tom: Gold Accent Card -->
    <div class="dashboard-card celebration-card border-gold">
        <div class="wall-avatar mx-auto mb-3" style="background-color: #332700; color: #eab308;">TW</div>
        <h5 class="mb-0 text-white">Tom W.</h5>
        <div class="text-green mb-3" style="font-size: 14px;">ResumeAI</div>
        <p class="text-muted" style="font-size: 13px;">AI resume builder — 2k users in 2 weeks</p>
    </div>

    <!-- The Empty Dotted Target Card -->
    <div class="dashboard-card celebration-card dotted-card">
        <div class="mx-auto mb-3" style="font-size: 28px;">👤</div>
        <p class="text-muted" style="font-size: 14px;">Your name<br>could be here</p>
    </div>

</div>
