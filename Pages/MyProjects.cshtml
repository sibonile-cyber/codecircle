@page
@model CodeCircle.Pages.MyProjectsModel
@{
    ViewData["Title"] = "My Projects";
}

<div class="mb-4">
    <h3 class="mb-1">My Projects</h3>
    <p class="text-muted">Track your builds and milestones</p>
</div>

<div class="dashboard-card" style="max-width: 400px;">
    <!-- Dynamic Status Badge -->
    <span id="project-status-badge" class="badge-building">● Building</span>

    <h4 class="mt-3">DevFlow</h4>
    <p class="text-muted" style="font-size: 14px;">AI-powered code review tool that gives contextual feedback on PRs automatically.</p>

    <!-- The Progress Bar -->
    <div class="progress-section mt-4">
        <div class="d-flex justify-content-between mb-2" style="font-size: 12px; color: var(--text-muted);">
            <span>Progress</span>
            <span id="progress-text-display">50%</span>
        </div>
        <div class="progress-track">
            <div id="progress-bar-fill" class="progress-fill" style="width: 50%;"></div>
        </div>
    </div>

    <!-- Interactive Milestones -->
    <div class="milestones-container mt-4">
        <label class="custom-checkbox">
            <input type="checkbox" class="milestone-checkbox" checked>
            <span class="checkmark"></span>
            <span class="label-text">Project setup & auth</span>
        </label>
        <label class="custom-checkbox">
            <input type="checkbox" class="milestone-checkbox" checked>
            <span class="checkmark"></span>
            <span class="label-text">Database schema</span>
        </label>
        <label class="custom-checkbox">
            <input type="checkbox" class="milestone-checkbox">
            <span class="checkmark"></span>
            <span class="label-text">Review engine</span>
        </label>
        <label class="custom-checkbox">
            <input type="checkbox" class="milestone-checkbox">
            <span class="checkmark"></span>
            <span class="label-text">Beta launch</span>
        </label>
    </div>

    <!-- Footer row: Date and the Help Action -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <div style="font-size: 12px; color: var(--text-muted);">Started 12 days ago</div>

        <!-- THIS HTML IS WHAT WAS MISSING: The Ask for Help Button -->
        <button type="button" id="ask-help-btn" class="btn btn-sm" style="border: 1px dashed #3b82f6; color: #3b82f6; background: transparent; font-size: 12px; border-radius: 20px;">
            + Ask for help
        </button>
    </div>

    <!-- THIS HTML IS WHAT WAS MISSING: The "Move to Wall" Button -->
    <a href="/CelebrationWall" id="publish-wall-btn" class="btn btn-green w-100 mt-4" style="display: none; font-weight: bold; text-align: center;">
        🚀 Send to Celebration Wall
    </a>
</div>

@section Scripts {
    <script>
        const checkboxes = document.querySelectorAll('.milestone-checkbox');
        const progressBar = document.getElementById('progress-bar-fill');
        const progressText = document.getElementById('progress-text-display');
        const badge = document.getElementById('project-status-badge');
        const publishBtn = document.getElementById('publish-wall-btn');

        // Logic for the Progress Bar and Status Changes
        function updateProgress() {
            const total = checkboxes.length;
            const checkedCount = document.querySelectorAll('.milestone-checkbox:checked').length;
            const percentage = Math.round((checkedCount / total) * 100);

            progressBar.style.width = percentage + '%';
            progressText.innerText = percentage + '%';

            // THE MAGIC: What happens at 100%
            if (percentage === 100) {
                badge.className = "badge-completed";
                badge.innerHTML = "★ Completed";
                publishBtn.style.display = "block"; // Reveal the final button
            } else {
                badge.className = "badge-building";
                badge.innerHTML = "● Building";
                publishBtn.style.display = "none";  // Hide the button
            }
        }

        checkboxes.forEach(box => {
            box.addEventListener('change', updateProgress);
        });

        // Run instantly on load
        updateProgress();

        // ---------------------------------------------
        // NEW Logic for the Custom Ask For Help Prompt
        // ---------------------------------------------
        document.getElementById('ask-help-btn').addEventListener('click', function () {
            // 1. Pop up a text box asking the user what they need
            const userRoleRequest = prompt("What kind of help do you need? (e.g., Business Analyst, QA Tester)");

            // 2. Make sure they typed something
            if (userRoleRequest && userRoleRequest.trim() !== "") {
                // 3. Update the button text
                this.innerText = "Needs " + userRoleRequest;

                // 4. Give it the cool blue badge styling
                this.style.border = "1px solid #3b82f6";
                this.style.backgroundColor = "rgba(59, 130, 246, 0.1)";
                this.style.cursor = "default";
            }
        });
    </script>
}
