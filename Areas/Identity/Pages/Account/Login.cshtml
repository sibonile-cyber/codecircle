@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<div class="container mt-5 pb-5">
    <!-- Exactly 650px wide to match the rest of the app -->
    <div style="max-width: 650px; margin: 0 auto;">
        <div class="card p-5 shadow-lg" style="background-color: #1A1E23; border: 1px solid #30363D; border-radius: 12px; border-bottom: 4px solid #58A6FF;">
            <section>
                <form id="account" method="post">
                    <h2 class="text-light text-center mb-4" style="font-weight: 700;">CodeCircle Log in</h2>

                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.Email" class="form-label" style="color: #8B949E; font-weight: 500; margin-bottom: 8px; display: block;">Email</label>
                        <input asp-for="Input.Email" class="form-control" style="background-color: #0D1117; color: white; border: 1px solid #30363D; border-radius: 6px; padding: 12px; width: 100%;" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.Password" class="form-label" style="color: #8B949E; font-weight: 500; margin-bottom: 8px; display: block;">Password</label>
                        <input asp-for="Input.Password" class="form-control" style="background-color: #0D1117; color: white; border: 1px solid #30363D; border-radius: 6px; padding: 12px; width: 100%;" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="checkbox mb-4" style="color: #8B949E;">
                        <label asp-for="Input.RememberMe" class="form-label">
                            <input class="form-check-input me-2" asp-for="Input.RememberMe" style="background-color: #0D1117; border: 1px solid #30363D;" />
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>

                    <div class="mb-4">
                        <button id="login-submit" type="submit" class="w-100 btn btn-lg" style="background-color: #238636; color: white; font-weight: 600; border-radius: 6px; border: none; padding: 12px;">Log in</button>
                    </div>

                    <div class="d-flex flex-column gap-3 mt-4 pt-4 text-center" style="border-top: 1px solid #30363D;">
                        <p class="m-0">
                            <a id="forgot-password" asp-page="./ForgotPassword" style="color: #58A6FF; text-decoration: none; font-size: 15px; font-weight: 500;">Forgot your password?</a>
                        </p>
                        <p class="m-0">
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" style="color: #58A6FF; text-decoration: none; font-size: 15px; font-weight: 500;">Register as a new user</a>
                        </p>
                        <p class="m-0">
                            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" style="color: #8B949E; text-decoration: none; font-size: 14px;">Resend email confirmation</a>
                        </p>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
