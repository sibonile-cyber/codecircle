@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Register confirmation";
}

<div class="container mt-5 pb-5">
    <div style="max-width: 650px; margin: 0 auto;">

        <div class="card p-5 shadow-lg text-center" style="background-color: #1A1E23; border: 1px solid #30363D; border-radius: 12px; border-bottom: 4px solid #58A6FF;">

            <div class="mb-4" style="font-size: 3rem;">✉️</div>
            <h2 class="text-light mb-4" style="font-weight: 700;">Account Created!</h2>

            <hr style="border-color: #30363D; margin: 20px 0;" />

            @{
                if (@Model.DisplayConfirmAccountLink)
                {
                    <p style="color: #8B949E; font-size: 1.1rem; margin-bottom: 25px;">
                        This platform does not currently have a live email server registered. <br />
                        Normally, a confirmation link would be emailed to you directly.
                    </p>

                    
                    <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="btn btn-lg w-100" style="background-color: #238636; color: white; font-weight: 600; border-radius: 6px; border: none; padding: 12px; font-size: 1.1rem; transition: background-color 0.2s;">
                        Proceed to Confirm Account
                    </a>
                }
                else
                {
                    <p style="color: #8B949E; font-size: 1.1rem;">
                        Please check your email inbox to confirm your account.
                    </p>
                }
            }
        </div>
    </div>
</div>
