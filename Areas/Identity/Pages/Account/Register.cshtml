@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="container mt-5 pb-5">
    <!-- Exactly 650px wide to match the rest of the app -->
    <div style="max-width: 650px; margin: 0 auto;">
        <div class="card p-5 shadow-lg" style="background-color: #1A1E23; border: 1px solid #30363D; border-radius: 12px; border-bottom: 4px solid #58A6FF;">
            <section>
                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <h2 class="text-light text-center mb-4" style="font-weight: 700;">Create an Account</h2>

                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.Email" class="form-label" style="color: #8B949E; font-weight: 500; margin-bottom: 8px; display: block;">Email</label>
                        <input asp-for="Input.Email" class="form-control" style="background-color: #0D1117; color: white; border: 1px solid #30363D; border-radius: 6px; padding: 12px; width: 100%;" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <!-- Password Field -->
<div class="form-group mb-4">
    <label asp-for="Input.Password" class="form-label" style="color: #8B949E; font-weight: 500; margin-bottom: 8px; display: block;">Password</label>
    <input asp-for="Input.Password" class="form-control" style="background-color: #0D1117; color: white; border: 1px solid #30363D; border-radius: 6px; padding: 12px; width: 100%;" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
    
    <!-- ADD THIS HINT TEXT RIGHT HERE! -->
    <div class="mt-2">
        <small style="color: #8B949E; font-size: 0.85rem;">
            * Password must be at least 6 characters and contain an uppercase letter, a number, and a special character (e.g. !@@#$).
        </small>
    </div>

    <span asp-validation-for="Input.Password" class="text-danger"></span>
</div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.Password" class="form-label" style="color: #8B949E; font-weight: 500; margin-bottom: 8px; display: block;">Password</label>
                        <input asp-for="Input.Password" class="form-control" style="background-color: #0D1117; color: white; border: 1px solid #30363D; border-radius: 6px; padding: 12px; width: 100%;" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label" style="color: #8B949E; font-weight: 500; margin-bottom: 8px; display: block;">Confirm Password</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" style="background-color: #0D1117; color: white; border: 1px solid #30363D; border-radius: 6px; padding: 12px; width: 100%;" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-2 mt-4">
                        <button id="registerSubmit" type="submit" class="w-100 btn btn-lg" style="background-color: #58A6FF; color: white; font-weight: 600; border-radius: 6px; border: none; padding: 12px;">Register</button>
                    </div>
                </form>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
